. $STF_SUITE/include/libtest.shlib

# produce a space-separated string of all the places where the given dataset is
# mounted. sorted for ease of comparison
function get_mount_paths #ds
{
	if is_linux ; then
		# testpool/testfs@snap /var/tmp/testdir/fs/.zfs/snapshot/snap zfs ro,relatime,xattr,noacl,casesensitive 0 0
		awk -v ds=$1 '$1 == ds { print $2 }' /proc/mounts | sort | xargs
	elif is_freebsd ; then
		# uses mount -v because snapmounts on FreeBSD are marked
		# "internal" and so invisible by default.

		# testpool/testfs@snap on /zts/tmp/testdir/fs/.zfs/snapshot/snap (zfs, local, noatime, nosuid, read-only, nfsv4acls, fsid de9c877ddee12ef7, vnodes: count 1 )
		mount -v | awk -v ds=$1 '$1 == ds { print $3 }' | sort | xargs
	else
		log_fail "get_mount_paths: no support for this platform"
	fi
}
